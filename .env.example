# PostgreSQL — Prisma + Supabase

# Shared Session pooler (IPv4). Copy from Supabase → Connect → Session pooler.
DATABASE_URL="postgresql://postgres.qeilcfjacuvokyelidnb:[YOUR-PASSWORD]@aws-1-us-east-1.pooler.supabase.com:5432/postgres"

# Direct connection (IPv6). Use if you are not on IPv4-only networks:
# DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.qeilcfjacuvokyelidnb.supabase.co:5432/postgres"

# ── Supabase Auth (operator console) ─────────────────────────────────────────
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-or-publishable-key"

# Next.js (optional)
# NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Diagnostics API (optional; required in production on /api/diagnostics)
# DIAGNOSTICS_SECRET="long-random-string"
